# ── Server ────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=digihr
DB_USER=postgres
DB_PASSWORD=Admin@123

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=digihr_super_secret_key_123456789
JWT_REFRESH_SECRET=digihr_refresh_secret_987654321
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Email (optional) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ── File uploads ──────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads